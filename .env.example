# Public Supabase client configuration. Never place a service-role or secret key in NEXT_PUBLIC_* variables.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Registration stays closed for Production until the legal launch guard is complete.
REGISTRATION_MODE=closed

# Central legal/operator configuration.
LEGAL_OPERATOR_NAME=Daniel Kanke
LEGAL_BUSINESS_NAME=
LEGAL_OPERATOR_STREET=
LEGAL_OPERATOR_POSTAL_CODE=
LEGAL_OPERATOR_CITY=Rheda-Wiedenbrück
LEGAL_OPERATOR_COUNTRY=Deutschland
LEGAL_CONTACT_EMAIL=
LEGAL_CONTACT_PHONE=
LEGAL_PRIVACY_APPROVED=false
LEGAL_IMPRINT_APPROVED=false
LEGAL_PROCESSORS_REVIEWED=false

# Local/server-only administration script. Never expose or commit its value.
SUPABASE_SECRET_KEY=
